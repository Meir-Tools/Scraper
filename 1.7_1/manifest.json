{
   "manifest_version": 3,
   "name": "Scraper",
   "version": "1.7.1",
   "description": "Scraper gets data out of web pages and into spreadsheets.",
   "icons": {
      "16": "img/scraper16.png",
      "32": "img/scraper32.png",
      "48": "img/scraper48.png",
      "128": "img/scraper128.png"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "content_scripts": [ {
      "js": [ "lib/jquery-ui-1.8.6/js/jquery-1.4.2.js", "lib/jquery-ui-1.8.6/js/jquery-ui-1.8.6.highlight.js", "js/shared.js", "js/bit155/attr.js", "js/bit155/scraper.js", "js/contentscript.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_start"
   } ],
   "oauth2": {
      "client_id": "713595600722-2s6ljlbm9d6icnkjum9anlrr87hj9gjk.apps.googleusercontent.com",
      "scopes": [ "https://www.googleapis.com/auth/drive", "https://www.googleapis.com/auth/drive.file" ]
   },
   "permissions": [ "identity", "tabs", "contextMenus", "clipboardWrite", "unlimitedStorage", "downloads" ],
   "host_permissions": [ "http://*/*", "https://*/*" ],
   "update_url": "https://clients2.google.com/service/update2/crx"
}
